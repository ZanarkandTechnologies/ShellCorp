{
  "id": "notion-shell",
  "name": "Shell Company Notion",
  "version": "0.1.0",
  "description": "Notion channel and helper methods for Shell Company MVP.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "defaultAccountId": {
        "type": "string",
        "default": "default"
      },
      "webhook": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "default": "/plugins/notion-shell/webhook"
          },
          "targetAgentId": {
            "type": "string",
            "default": "main"
          },
          "verificationToken": {
            "type": "string"
          }
        }
      }
    }
  },
  "uiHints": {
    "defaultAccountId": {
      "label": "Default Notion Account ID",
      "placeholder": "default"
    },
    "webhook.path": {
      "label": "Webhook Path",
      "placeholder": "/plugins/notion-shell/webhook"
    },
    "webhook.targetAgentId": {
      "label": "Target Agent ID",
      "placeholder": "main"
    }
  }
}
